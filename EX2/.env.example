# --- API Gateway Configuration ---
PORT=3000

# --- Microservices URLs (Used by API Gateway) ---
USER_SERVICE_URL=http://localhost:3001
BOT_SERVICE_URL=http://localhost:3002
GAME_SERVICE_URL=http://localhost:3003
REPORTING_SERVICE_URL=http://localhost:3004

# --- Database Configurations (Used by microservices) ---
# Connection string for MongoDB (Local or Atlas)
MONGO_URI=mongodb://localhost:27017/english_learning_bot

# --- Ports for individual microservices ---
USER_SERVICE_PORT=3001
BOT_SERVICE_PORT=3002
GAME_SERVICE_PORT=3003
REPORTING_SERVICE_PORT=3004
